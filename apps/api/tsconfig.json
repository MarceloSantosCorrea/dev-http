{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strictPropertyInitialization": false,
    "paths": {
      "@devhttp/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@devhttp/shared": [
        "../../packages/shared/src/index.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
